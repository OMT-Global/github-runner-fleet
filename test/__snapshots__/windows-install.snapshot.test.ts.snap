// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`buildWindowsDockerInstallPlan snapshots > locks the full Windows Docker install plan JSON shape 1`] = `
{
  "composeContent": "# Generated by pnpm render-windows-compose
# Windows Docker runners: dedicated Windows host, ephemeral one-job runners, explicit Docker named-pipe mount.
name: github-runner-fleet-windows-docker
services:
  windows-private-runner-01:
    image: ghcr.io/example/github-runner-fleet:0.1.9-windows
    container_name: windows-private-runner-01
    hostname: windows-private-runner-01
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: windows-private-runner-01
      RUNNER_GROUP: windows-private
      RUNNER_LABELS: windows,docker-capable,private,x64
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: selected
      RUNNER_STATE_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01
      RUNNER_LOG_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01\\logs
      RUNNER_WORK_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01\\_work
      RUNNER_TEMP: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01\\_temp
      RUNNER_TOOL_CACHE: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01\\toolcache
      AGENT_TOOLSDIRECTORY: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01\\toolcache
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
      DOCKER_HOST: npipe:////./pipe/docker_engine
      RUNNER_ALLOWED_REPOSITORIES: example/windows-app
    volumes:
      - C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01:C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01
      - type: npipe
        source: \\\\.\\pipe\\docker_engine
        target: \\\\.\\pipe\\docker_engine
    labels:
      com.github-runner-fleet.pool: windows-private
      com.github-runner-fleet.plane: windows-docker
      com.github-runner-fleet.visibility: private
      com.github-runner-fleet.repository-access: selected
      com.github-runner-fleet.allowed-repositories: example/windows-app
      com.github-runner-fleet.docker-capable: "true"
    cpus: "4"
    pids_limit: 1024
    mem_limit: 8g
  windows-private-runner-02:
    image: ghcr.io/example/github-runner-fleet:0.1.9-windows
    container_name: windows-private-runner-02
    hostname: windows-private-runner-02
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: windows-private-runner-02
      RUNNER_GROUP: windows-private
      RUNNER_LABELS: windows,docker-capable,private,x64
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: selected
      RUNNER_STATE_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02
      RUNNER_LOG_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02\\logs
      RUNNER_WORK_DIR: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02\\_work
      RUNNER_TEMP: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02\\_temp
      RUNNER_TOOL_CACHE: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02\\toolcache
      AGENT_TOOLSDIRECTORY: C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02\\toolcache
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
      DOCKER_HOST: npipe:////./pipe/docker_engine
      RUNNER_ALLOWED_REPOSITORIES: example/windows-app
    volumes:
      - C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02:C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02
      - type: npipe
        source: \\\\.\\pipe\\docker_engine
        target: \\\\.\\pipe\\docker_engine
    labels:
      com.github-runner-fleet.pool: windows-private
      com.github-runner-fleet.plane: windows-docker
      com.github-runner-fleet.visibility: private
      com.github-runner-fleet.repository-access: selected
      com.github-runner-fleet.allowed-repositories: example/windows-app
      com.github-runner-fleet.docker-capable: "true"
    cpus: "4"
    pids_limit: 1024
    mem_limit: 8g",
  "connection": {
    "host": "windows-host.example.com",
    "port": "22",
    "username": "administrator",
  },
  "deploymentScript": "$ErrorActionPreference = 'Stop'
$ProjectDir = 'C:\\github-runner-fleet\\windows-docker'
$ComposeFile = 'C:\\github-runner-fleet\\windows-docker\\compose.yaml'
$ProjectName = 'github-runner-fleet-windows-docker'
$LogFile = 'C:\\github-runner-fleet\\windows-docker\\logs\\install-project.log'
New-Item -ItemType Directory -Force -Path (Split-Path -Parent $LogFile) | Out-Null
Start-Transcript -Path $LogFile -Append | Out-Null
try {
  Write-Host "[install] $(Get-Date -Format o) starting $ProjectName"
  $Docker = (Get-Command docker -ErrorAction Stop).Source
  $Directories = @('C:\\github-runner-fleet\\windows-docker', 'C:\\github-runner-fleet\\windows-docker\\logs', 'C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01', 'C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02')
  foreach ($Directory in $Directories) {
    New-Item -ItemType Directory -Force -Path $Directory | Out-Null
  }
  Set-Location $ProjectDir
  & $Docker compose -p $ProjectName -f $ComposeFile config -q
  & $Docker compose -p $ProjectName -f $ComposeFile pull
  & $Docker compose -p $ProjectName -f $ComposeFile up -d --force-recreate --remove-orphans
  & $Docker compose -p $ProjectName -f $ComposeFile ps
  Write-Host "[install] $(Get-Date -Format o) completed $ProjectName"
} finally {
  Stop-Transcript | Out-Null
}
",
  "envFileContent": "GITHUB_PAT="fixture-token"
GITHUB_API_URL="https://api.github.com"
",
  "options": {
    "action": "up",
    "forceRecreate": true,
    "pullImages": true,
    "removeOrphans": true,
    "removeVolumes": false,
  },
  "project": {
    "composeFileName": "compose.yaml",
    "deploymentScriptName": "Deploy-WindowsDocker.ps1",
    "directory": "C:\\github-runner-fleet\\windows-docker",
    "envFileName": ".env",
    "logFileName": "install-project.log",
    "name": "github-runner-fleet-windows-docker",
  },
  "stateDirectories": [
    "C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-01",
    "C:\\github-runner-fleet\\windows-docker\\pools\\windows-private\\runner-02",
  ],
}
`;
