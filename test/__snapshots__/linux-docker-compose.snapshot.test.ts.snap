// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderLinuxDockerCompose snapshots > locks the full Linux Docker docker-compose YAML 1`] = `
"# Generated by pnpm render-linux-docker-compose
# Linux Docker runners: dedicated Docker host, ephemeral one-job runners, explicit Docker socket mount.
name: github-runner-fleet-linux-docker
services:
  linux-docker-private-runner-01:
    image: ghcr.io/example/github-runner-fleet:0.1.9
    container_name: linux-docker-private-runner-01
    hostname: linux-docker-private-runner-01
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: linux-docker-private-runner-01
      RUNNER_GROUP: linux-docker-private
      FLEET_POOL_KEY: linux-docker-private
      FLEET_PLANE: linux-docker
      RUNNER_LABELS: linux,docker-capable,private,x64
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: selected
      RUNNER_STATE_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01
      RUNNER_LOG_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01/logs
      RUNNER_WORK_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01/_work
      RUNNER_TEMP: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01/_temp
      RUNNER_TOOL_CACHE: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01/toolcache
      AGENT_TOOLSDIRECTORY: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01/toolcache
      RUNNER_EXEC_MODE_OVERRIDE: root
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
      DOCKER_HOST: unix:///var/run/docker.sock
      RUNNER_ALLOWED_REPOSITORIES: example/private-app
    volumes:
      - /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01:/srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-01
      - /var/run/docker.sock:/var/run/docker.sock
    labels:
      com.github-runner-fleet.pool: linux-docker-private
      com.github-runner-fleet.plane: linux-docker
      com.github-runner-fleet.visibility: private
      com.github-runner-fleet.repository-access: selected
      com.github-runner-fleet.allowed-repositories: example/private-app
      com.github-runner-fleet.docker-capable: "true"
    platform: linux/amd64
    cpus: "4"
    pids_limit: 1024
    mem_limit: 8g
  linux-docker-private-runner-02:
    image: ghcr.io/example/github-runner-fleet:0.1.9
    container_name: linux-docker-private-runner-02
    hostname: linux-docker-private-runner-02
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: linux-docker-private-runner-02
      RUNNER_GROUP: linux-docker-private
      FLEET_POOL_KEY: linux-docker-private
      FLEET_PLANE: linux-docker
      RUNNER_LABELS: linux,docker-capable,private,x64
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: selected
      RUNNER_STATE_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02
      RUNNER_LOG_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02/logs
      RUNNER_WORK_DIR: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02/_work
      RUNNER_TEMP: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02/_temp
      RUNNER_TOOL_CACHE: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02/toolcache
      AGENT_TOOLSDIRECTORY: /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02/toolcache
      RUNNER_EXEC_MODE_OVERRIDE: root
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
      DOCKER_HOST: unix:///var/run/docker.sock
      RUNNER_ALLOWED_REPOSITORIES: example/private-app
    volumes:
      - /srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02:/srv/github-runner-fleet/linux-docker/pools/linux-docker-private/runner-02
      - /var/run/docker.sock:/var/run/docker.sock
    labels:
      com.github-runner-fleet.pool: linux-docker-private
      com.github-runner-fleet.plane: linux-docker
      com.github-runner-fleet.visibility: private
      com.github-runner-fleet.repository-access: selected
      com.github-runner-fleet.allowed-repositories: example/private-app
      com.github-runner-fleet.docker-capable: "true"
    platform: linux/amd64
    cpus: "4"
    pids_limit: 1024
    mem_limit: 8g"
`;
