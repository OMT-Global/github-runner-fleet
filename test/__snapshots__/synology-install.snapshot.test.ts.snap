    labels:
      com.synology-gh-runner.pool: synology-private
      com.synology-gh-runner.visibility: private
      com.synology-gh-runner.repository-access: all
      com.synology-gh-runner.allowed-repositories: all
      com.synology-gh-runner.shell-only: "true"
    mem_limit: 2g
  synology-public-runner-01:
    image: ghcr.io/example/github-runner-fleet:0.1.9
    container_name: synology-public-runner-01
    hostname: synology-public-runner-01
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: synology-public-runner-01
      RUNNER_GROUP: synology-public
      FLEET_POOL_KEY: synology-public
      FLEET_PLANE: synology
      RUNNER_LABELS: synology,shell-only,public
      RUNNER_VISIBILITY: public
      RUNNER_REPOSITORY_ACCESS: selected
      RUNNER_STATE_DIR: /volume1/docker/github-runner-fleet/pools/synology-public/runner-01
      RUNNER_LOG_DIR: /volume1/docker/github-runner-fleet/pools/synology-public/runner-01/logs
      RUNNER_WORK_DIR: /tmp/github-runner-work
      RUNNER_TEMP: /tmp/github-runner-temp
      RUNNER_TOOL_CACHE: /opt/hostedtoolcache
      AGENT_TOOLSDIRECTORY: /opt/hostedtoolcache
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
      RUNNER_ALLOWED_REPOSITORIES: example/public-demo
    volumes:
      - /volume1/docker/github-runner-fleet/pools/synology-public/runner-01:/volume1/docker/github-runner-fleet/pools/synology-public/runner-01
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    labels:
      com.synology-gh-runner.pool: synology-public
      com.synology-gh-runner.visibility: public
      com.synology-gh-runner.repository-access: selected
      com.synology-gh-runner.allowed-repositories: example/public-demo
      com.synology-gh-runner.shell-only: "true"
    platform: linux/arm64
    cpus: "2"
    pids_limit: 512
    mem_limit: 1g",
  "connection": {
    "apiRepo": "/Users/tester/src/synology-api",
    "certVerify": false,
    "dsmVersion": 7,
    "host": "nas.example.com",
    "password": "fake-password",
    "port": "5001",
    "secure": true,
    "username": "admin",
  },
  "deploymentScript": "#!/bin/sh
set -eu
project_dir='/volume1/docker/github-runner-fleet'
compose_file='compose.yaml'
project_name='github-runner-fleet'
log_file='/volume1/docker/github-runner-fleet/logs/install-project.log'
mkdir -p "$(dirname "$log_file")"
exec >>"$log_file" 2>&1
printf '[install] %s starting %s\\n' "$(date -Iseconds)" "$project_name"
docker_bin=''
for candidate in /usr/local/bin/docker /usr/bin/docker docker; do
  if [ -x "$candidate" ]; then
    docker_bin="$candidate"
    break
  fi
  if command -v "$candidate" >/dev/null 2>&1; then
    docker_bin="$(command -v "$candidate")"
    break
  fi
done
if [ -z "$docker_bin" ]; then
  echo 'docker binary not found on NAS'
  exit 1
fi
mkdir -p '/volume1/docker/github-runner-fleet' '/volume1/docker/github-runner-fleet/logs' '/volume1/docker/github-runner-fleet/pools/synology-private/runner-01' '/volume1/docker/github-runner-fleet/pools/synology-private/runner-02' '/volume1/docker/github-runner-fleet/pools/synology-public/runner-01'
cd "$project_dir"
"$docker_bin" compose -p "$project_name" -f "$compose_file" config -q
"$docker_bin" compose -p "$project_name" -f "$compose_file" pull
"$docker_bin" compose -p "$project_name" -f "$compose_file" up -d --force-recreate --remove-orphans
"$docker_bin" compose -p "$project_name" -f "$compose_file" ps
printf '[install] %s completed %s\\n' "$(date -Iseconds)" "$project_name"
",
  "envFileContent": "GITHUB_PAT="fixture-token"
GITHUB_API_URL="https://api.github.com"
",
  "options": {
    "action": "up",
    "forceRecreate": true,
    "pullImages": true,
    "removeOrphans": true,
    "removeVolumes": false,
  },
  "project": {
    "composeFileName": "compose.yaml",
    "directory": "/volume1/docker/github-runner-fleet",
    "envFileName": ".env",
    "logFileName": "install-project.log",
    "name": "github-runner-fleet",
  },
  "stateDirectories": [
    "/volume1/docker/github-runner-fleet/pools/synology-private/runner-01",
    "/volume1/docker/github-runner-fleet/pools/synology-private/runner-02",
    "/volume1/docker/github-runner-fleet/pools/synology-public/runner-01",
  ],
}
`;
