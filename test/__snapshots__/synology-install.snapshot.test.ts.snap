exports[`buildSynologyInstallPlan snapshots > locks the full Synology install plan JSON shape 1`] = `
{
  "composeContent": "# Generated by pnpm render-compose --output docker-compose.generated.yml
# Shell-only runners: no Docker socket, no privileged mode, no published ports.
name: github-runner-fleet
services:
  synology-private-runner-01:
    image: ghcr.io/example/github-runner-fleet:0.1.9
    container_name: synology-private-runner-01
    hostname: synology-private-runner-01
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: synology-private-runner-01
      RUNNER_GROUP: synology-private
      FLEET_POOL_KEY: synology-private
      FLEET_PLANE: synology
      RUNNER_LABELS: synology,shell-only,private
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: all
      RUNNER_STATE_DIR: /volume1/docker/github-runner-fleet/pools/synology-private/runner-01
      RUNNER_LOG_DIR: /volume1/docker/github-runner-fleet/pools/synology-private/runner-01/logs
      RUNNER_WORK_DIR: /tmp/github-runner-work
      RUNNER_TEMP: /tmp/github-runner-temp
      RUNNER_TOOL_CACHE: /opt/hostedtoolcache
      AGENT_TOOLSDIRECTORY: /opt/hostedtoolcache
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
    volumes:
      - /volume1/docker/github-runner-fleet/pools/synology-private/runner-01:/volume1/docker/github-runner-fleet/pools/synology-private/runner-01
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    labels:
      com.synology-gh-runner.pool: synology-private
      com.synology-gh-runner.visibility: private
      com.synology-gh-runner.repository-access: all
      com.synology-gh-runner.allowed-repositories: all
      com.synology-gh-runner.shell-only: "true"
    mem_limit: 2g
  synology-private-runner-02:
    image: ghcr.io/example/github-runner-fleet:0.1.9
    container_name: synology-private-runner-02
    hostname: synology-private-runner-02
    restart: unless-stopped
    stop_grace_period: 2m
    environment:
      GITHUB_PAT: \${GITHUB_PAT}
      GITHUB_API_URL: \${GITHUB_API_URL:-https://api.github.com}
      GITHUB_ORG: example
      RUNNER_SCOPE: organization
      RUNNER_NAME: synology-private-runner-02
      RUNNER_GROUP: synology-private
      FLEET_POOL_KEY: synology-private
      FLEET_PLANE: synology
      RUNNER_LABELS: synology,shell-only,private
      RUNNER_VISIBILITY: private
      RUNNER_REPOSITORY_ACCESS: all
      RUNNER_STATE_DIR: /volume1/docker/github-runner-fleet/pools/synology-private/runner-02
      RUNNER_LOG_DIR: /volume1/docker/github-runner-fleet/pools/synology-private/runner-02/logs
      RUNNER_WORK_DIR: /tmp/github-runner-work
      RUNNER_TEMP: /tmp/github-runner-temp
      RUNNER_TOOL_CACHE: /opt/hostedtoolcache
      AGENT_TOOLSDIRECTORY: /opt/hostedtoolcache
      RUNNER_EPHEMERAL: "true"
      RUNNER_DISABLE_UPDATE: "true"
    volumes:
      - /volume1/docker/github-runner-fleet/pools/synology-private/runner-02:/volume1/docker/github-runner-fleet/pools/synology-private/runner-02
    security_opt:
      - no-new-privileges:true
    cap_drop:
